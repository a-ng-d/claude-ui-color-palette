{
  "mcpServers": {
    "ui-color-palette": {
      "type": "http",
      "url": "https://mcp-uicp.yelbolt.workers.dev/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "figma-desktop": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "penpot": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "http://localhost:4401/sse", "--allow-http"]
    },
    "sketch": {
      "type": "http",
      "url": "http://localhost:31126/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "gitlab": {
      "type": "http",
      "url": "${user_config.gitlab_url}/api/v4/mcp"
    },
    "framer": {
      "type": "http",
      "url": "${user_config.framer_mcp_url}"
    }
  }
}
